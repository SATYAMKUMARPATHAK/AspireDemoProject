    "apigateway": {
      "type": "project.v0",
      "path": "../AspireECommerceDemo.ApiGateway/AspireECommerceDemo.ApiGateway.csproj",
      "env": {
        "OTEL_DOTNET_EXPERIMENTAL_OTLP_RETRY": "in_memory",
        "ASPNETCORE_FORWARDEDHEADERS_ENABLED": "true",
        "HTTP_PORTS": "{apigateway.bindings.http.targetPort}",
        "CATALOGSERVICE_HTTP": "{catalogservice.bindings.http.url}",
        "services__catalogservice__http__0": "{catalogservice.bindings.http.url}",
        "ORDERSERVICE_HTTP": "{orderservice.bindings.http.url}",
        "services__orderservice__http__0": "{orderservice.bindings.http.url}",
        "PAYMENTSERVICE_HTTP": "{paymentservice.bindings.http.url}",
        "services__paymentservice__http__0": "{paymentservice.bindings.http.url}",
        "NOTIFICATIONSERVICE_HTTP": "{notificationservice.bindings.http.url}",
        "services__notificationservice__http__0": "{notificationservice.bindings.http.url}",
