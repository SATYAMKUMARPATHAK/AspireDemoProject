        "NOTIFICATIONDB_URI": "mssql://sa:{sql-password.value}@{sql.bindings.tcp.host}:{sql.bindings.tcp.port}/notificationdb",
        "NOTIFICATIONDB_JDBCCONNECTIONSTRING": "jdbc:sqlserver://{sql.bindings.tcp.host}:{sql.bindings.tcp.port};databaseName=notificationdb;trustServerCertificate=true",
        "NOTIFICATIONDB_DATABASENAME": "notificationdb",
