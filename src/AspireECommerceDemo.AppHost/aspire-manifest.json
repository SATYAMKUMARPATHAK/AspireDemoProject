        "ORDERDB_PORT": "{sql.bindings.tcp.port}",
        "ORDERDB_USERNAME": "sa",
        "ORDERDB_PASSWORD": "{sql-password.value}",
        "ORDERDB_URI": "mssql://sa:{sql-password.value}@{sql.bindings.tcp.host}:{sql.bindings.tcp.port}/orderdb",
        "ORDERDB_JDBCCONNECTIONSTRING": "jdbc:sqlserver://{sql.bindings.tcp.host}:{sql.bindings.tcp.port};databaseName=orderdb;trustServerCertificate=true",
        "ORDERDB_DATABASENAME": "orderdb",
        "ConnectionStrings__messaging": "{messaging.connectionString}",
        "MESSAGING_HOST": "{messaging.bindings.tcp.host}",
        "MESSAGING_PORT": "{messaging.bindings.tcp.port}",
        "MESSAGING_USERNAME": "guest",
        "MESSAGING_PASSWORD": "{messaging-password.value}",
        "MESSAGING_URI": "amqp://guest:{messaging-password-uri-encoded.value}@{messaging.bindings.tcp.host}:{messaging.bindings.tcp.port}"
      },
      "bindings": {
        "http": {
          "scheme": "http",
          "protocol": "tcp",
          "transport": "http"
        }
      }
    },
    "paymentservice": {
      "type": "project.v0",
      "path": "../AspireECommerceDemo.PaymentService/AspireECommerceDemo.PaymentService.csproj",
