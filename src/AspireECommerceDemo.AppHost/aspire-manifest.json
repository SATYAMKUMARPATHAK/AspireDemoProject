        "PAYMENTDB_PORT": "{sql.bindings.tcp.port}",
        "PAYMENTDB_USERNAME": "sa",
        "PAYMENTDB_PASSWORD": "{sql-password.value}",
        "PAYMENTDB_URI": "mssql://sa:{sql-password.value}@{sql.bindings.tcp.host}:{sql.bindings.tcp.port}/paymentdb",
