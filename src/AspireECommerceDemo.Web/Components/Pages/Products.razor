@page "/products"
@rendermode InteractiveServer
@inject CatalogApiClient CatalogApi
@inject CartService Cart

<PageTitle>Products | AspireStore</PageTitle>

<div class="container animate-fade-in py-8">
    <div class="flex justify-between items-center mb-8 flex-col sm:flex-row gap-4">
        <h2 class="brand-font m-0 text-3xl">All Products</h2>
        <div class="flex gap-4 items-center w-full sm:w-auto">
            <div style="position: relative; flex-grow: 1;">
                <input type="text" class="form-control" placeholder="Search products..." @bind="searchQuery" @bind:event="oninput" @onkeyup="PerformSearch" style="margin-bottom: 0; padding-left: 2.5rem; min-width: 250px;" />
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="position: absolute; left: 12px; top: 50%; transform: translateY(-50%); color: var(--text-muted);">
                    <circle cx="11" cy="11" r="8"></circle>
                    <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
            </div>
            <select class="form-control" @onchange="FilterByCategory" style="margin-bottom: 0; min-width: 180px;">
                <option value="">All Categories</option>
                @foreach (var cat in categories)
                {
                    <option value="@cat.Id">@cat.Name</option>
                }
            </select>
        </div>
    </div>

    @if (loading)
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            @for (int i = 0; i < 8; i++)
            {
                <div class="card flex flex-col justify-center items-center" style="min-height: 350px;">
                    <div style="width: 40px; height: 40px; border-radius: 50%; border: 3px solid var(--border-color); border-top-color: var(--primary); animation: spin 1s linear infinite;"></div>
                </div>
            }
        </div>
    }
    else if (!products.Any())
    {
        <div class="glass-panel text-center py-16">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-muted mb-4" style="margin: 0 auto;">
                <circle cx="12" cy="12" r="10"></circle>
                <line x1="12" y1="8" x2="12" y2="12"></line>
                <line x1="12" y1="16" x2="12.01" y2="16"></line>
            </svg>
            <h3 class="text-2xl font-bold mb-2">No products found</h3>
            <p class="text-muted">Try adjusting your search or category filters.</p>
            <button class="btn btn-primary mt-6" @onclick="ClearFilters">Clear Filters</button>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6">
            @foreach (var p in products)
            {
                <div class="card flex flex-col animate-fade-in delay-100">
                    <a href="/product/@p.Id">
                        <div class="card-img-container">
                            <img src="@p.ImageUrl" alt="@p.Name" class="card-img" onerror="this.onerror=null; this.src='https://placehold.co/300x200/e4e4e7/18181b?text=Product';" />
                        </div>
                    </a>
                    
                    <div class="flex-1">
                        <a href="/product/@p.Id"><h4 class="font-bold text-lg mb-1">@p.Name</h4></a>
                        <p class="text-sm text-muted mb-3">@p.CategoryName</p>
                        <p class="text-xl font-bold text-gradient mb-4">@p.Price.ToString("C")</p>
                    </div>
                    
                    <div class="flex gap-2 mt-auto">
                        <a href="/product/@p.Id" class="btn btn-secondary flex-1">Details</a>
                        <button class="btn btn-primary flex-1" @onclick="() => AddToCart(p)">Add to Cart</button>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    @@keyframes spin {
        0% { transform: rotate(0deg); }
        100% { transform: rotate(360deg); }
    }
</style>

@code {
    private List<ProductDto> products = new();
    private List<CategoryDto> categories = new();
    private bool loading = true;
    private string searchQuery = "";
    private Guid? selectedCategory = null;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            categories = await CatalogApi.GetCategoriesAsync();
            await LoadProductsAsync();
        }
        finally
        {
            loading = false;
        }
    }

    private async Task LoadProductsAsync()
    {
        loading = true;
        StateHasChanged();
        
        try {
            if (!string.IsNullOrWhiteSpace(searchQuery))
            {
                products = await CatalogApi.SearchProductsAsync(searchQuery);
            }
            else
            {
                products = await CatalogApi.GetProductsAsync();
            }

            if (selectedCategory.HasValue)
            {
                products = products.Where(p => p.CategoryId == selectedCategory.Value).ToList();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading products: {ex.Message}");
            products = new();
        }
        finally
        {
            loading = false;
            StateHasChanged();
        }
    }

    private async Task PerformSearch(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" || string.IsNullOrWhiteSpace(searchQuery))
        {
            await LoadProductsAsync();
        }
    }

    private async Task FilterByCategory(ChangeEventArgs e)
    {
        if (Guid.TryParse(e.Value?.ToString(), out var id))
            selectedCategory = id;
        else
            selectedCategory = null;
            
        await LoadProductsAsync();
    }
    
    private async Task ClearFilters()
    {
        searchQuery = "";
        selectedCategory = null;
        await LoadProductsAsync();
    }

    private void AddToCart(ProductDto p)
    {
        Cart.AddItem(p.Id, p.Name, p.Price, p.ImageUrl);
    }
}
