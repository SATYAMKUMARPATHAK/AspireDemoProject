@inherits LayoutComponentBase
@implements IDisposable
@inject CartService Cart

<div class="min-h-screen flex flex-col">
    <nav class="glass-nav py-4 px-4">
        <div class="container flex justify-between items-center">
            <a href="/" class="brand-font text-2xl text-gradient font-bold" style="letter-spacing: -1px;">
                AspireStore.
            </a>
            
            <div class="flex items-center gap-6">
                <NavMenu />
                
                <a href="/cart" class="btn btn-primary" style="position: relative;">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="9" cy="21" r="1"></circle>
                        <circle cx="20" cy="21" r="1"></circle>
                        <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                    </svg>
                    Cart
                    @if (Cart.Count > 0)
                    {
                        <span class="badge badge-warning" style="position: absolute; top: -8px; right: -8px; padding: 2px 6px; font-size: 0.7rem;">@Cart.Count</span>
                    }
                </a>
            </div>
        </div>
    </nav>

    <main class="flex-1">
        <article class="content">
            @Body
        </article>
    </main>

    <footer class="py-8 mt-16" style="border-top: 1px solid var(--border-color); background: rgba(244, 244, 245, 0.5);">
        <div class="container text-center text-muted text-sm">
            &copy; 2026 AspireStore Demo. Built with .NET Aspire & Blazor.
        </div>
    </footer>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">🗙</a>
</div>

@code {
    protected override void OnInitialized()
    {
        Cart.OnChange += StateHasChanged;
    }

    public void Dispose()
    {
        Cart.OnChange -= StateHasChanged;
    }
}
